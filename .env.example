# Magister env template. Copy to `.env` (default profile) or
# `.env.<profile>` for `bash scripts/restart-profile.sh <profile>`.
# All keys below are optional; absence falls back to a sensible default.
#
# Provider API keys live in `config/secrets.json` (gitignored), NOT here.
# See CLAUDE.md § "Config".
#
# Env var prefixes: most user-facing settings use the `MAGISTER_*` prefix
# (legacy but active — e.g. MAGISTER_API_TARGET, MAGISTER_WEB_AUTH_PASS,
# MAGISTER_DB_PATH). Safety/runtime knobs use `MAGISTER_*` (e.g.
# MAGISTER_EXECUTION_SANDBOX_MODE, MAGISTER_PERMISSIONS_V4, MAGISTER_INSTALL_DIR).
# The code reads these exact names — guessing the wrong prefix has no effect.

# ---- HTTP ports / endpoints ----
# API port the Fastify server binds to. Default 3700.
PORT=3700
# API bind host (127.0.0.1 = loopback, 0.0.0.0 = all interfaces). Default 127.0.0.1.
HOST=127.0.0.1
# Web bundle port (served by apps/web/serve-prod.ts). Default 3701.
WEB_PORT=3701
# Where the web bundle proxies its API calls. Must match PORT.
MAGISTER_API_TARGET=http://127.0.0.1:3700

# API auth token. When set, every API request (except /health) must send
# `Authorization: Bearer <token>`. When unset, the API is unauthenticated
# but only allowed to bind loopback (127.0.0.1); binding 0.0.0.0 without a
# token aborts startup. The web console proxy injects this server-side.
MAGISTER_API_TOKEN=

# When "off", GET /settings/providers/:id/secret never returns the key
# value (only whether one is configured). Default "on" — the reveal is
# behind API auth. Set "off" for hardened deployments.
MAGISTER_ALLOW_SECRET_REVEAL=on

# ---- Profile / install anchoring ----
# Free-form tag exposed at /diagnostics. Set by restart-profile.sh.
MAGISTER_RUNTIME_PROFILE=
# Anchor for safe-apply's path-sensitivity classifier (Magister's own
# install dir — secrets.json, .magister/, .ultimate/ are critical
# under it). Defaults to the repo root when launched via restart.sh.
MAGISTER_INSTALL_DIR=

# ---- Channels (Feishu) ----
# Set to 1 in dev profiles so a dev instance cannot claim the prod
# Feishu websocket or send outbound messages even if bot credentials
# leak into its environment. See CLAUDE.md § "Prod controls Dev workspace".
MAGISTER_DISABLE_CHANNELS=
# Feishu bot credentials. Leave empty if not using the Feishu channel.
MAGISTER_FEISHU_APP_ID=
MAGISTER_FEISHU_APP_SECRET=

# ---- Web console basic auth (optional) ----
MAGISTER_WEB_AUTH_USER=
MAGISTER_WEB_AUTH_PASS=
MAGISTER_WEB_BASE_URL=

# ---- External integrations ----
MAGISTER_TAVILY_WEB_SEARCH_API_KEY=
MAGISTER_TAVILY_WEB_SEARCH_ENABLED=

# ---- Safe-apply v4 (sandbox elevation) ----
# Permissions-v4 feature gate. Code default is off (must be exact
# string "on" to enable), but the .env.example default is ON because
# the three-tier permissions model (use_default / with_additional_permissions
# / require_escalated) is the recommended baseline — leader can request
# specific path/network elevation per call with user approval, instead
# of failing closed at the sandbox boundary. Set to empty to revert
# to v3 single-shot approval. See CLAUDE.md § Safety.
MAGISTER_PERMISSIONS_V4=on
# Sandbox mode for bash execution: "off" | "optional" | "required".
# Default "optional" — runs bash inside bwrap when available.
MAGISTER_EXECUTION_SANDBOX_MODE=

# Max wall-clock (ms) for a CLI teammate (codex/claude-code/opencode/kiro)
# spawned by the leader. On timeout the child is terminated and reported
# as a failed teammate. Default 1800000 (30 min).
MAGISTER_CLI_TEAMMATE_TIMEOUT_MS=1800000
